{
  "build": {
    "content": [
      {
        "files": [ "**/*.{md,yml}" ],
        "exclude": [
          "_site/**",
          "templates/**",
          "artops-template/**",
          "**/node_modules/**",
          "obj/**"
        ]
      }
    ],

    "resource": [
      {
        "files": [ "images/**" ]
      }
    ],

    "output": "_site",

    "template": [
      "default",
      "modern",
      "artops-template"
    ],

    "postProcessors": [ "ExtractSearchIndex" ],

    "globalMetadata": {
      "_appTitle":    "ArtOps — AI Self-Portrait Agent Pack",
      "_appName":     "ArtOps",
      "_appLogoPath": "images/artops-logo.svg",
      "_appFaviconPath": "images/artops-logo.svg",
      "_appFooter":   "© 2026 Tooensure LLC — Proprietary Cognitive Asset · Built on PMCRO 2.0.0",
      "_enableSearch":        true,
      "_enableNewTab":        true,
      "_disableContribution": false,
      "_disableBreadcrumb":   false,
      "_disableTocFilter":    false,
      "_noindex":             false,
      "_gitContribute": {
        "repo":   "https://github.com/ShawnDelaineBellazanLoop/artops-portable",
        "branch": "main"
      }
    },

    "fileMetadata": {
      "_category": {
        "articles/agents/**": "agent-reference",
        "articles/guides/**": "guide",
        "articles/changelog.md": "changelog",
        "articles/roadmap.md":   "roadmap",
        "articles/**":           "conceptual"
      },
      "_enableContribution": {
        "articles/**": true
      }
    },

    "sitemap": {
      "baseUrl":    "https://ShawnDelaineBellazanLoop.github.io/artops-portable",
      "priority":   0.5,
      "changefreq": "weekly"
    },

    "warningsAsErrors": false,
    "logLevel": "Warning",

    "markdownEngineProperties": {
      "markdigExtensions": [
        "abbreviations",
        "definitionlists",
        "figures",
        "bootstrap",
        "emphasisextras",
        "pipetables",
        "tasklists",
        "diagrams"
      ]
    }
  }
}
